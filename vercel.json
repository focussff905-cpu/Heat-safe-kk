{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/notify", "schedule": "0 0 * * *" },
    { "path": "/api/notify", "schedule": "30 4 * * *" },
    { "path": "/api/notify", "schedule": "0 8 * * *" }
  ]
}
